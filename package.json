{
  "name": "@wehi-soda-hub/rdf-viewer",
  "private": false,
  "type": "module",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./filterRdfs": {
      "import": "./dist-cli/filterRdfs.js",
      "types": "./dist-cli/filterRdfs.d.ts"
    }
  },
  "bin": {
    "filter-rdfs": "./dist-cli/bin/filterRdfs.js"
  },
  "files": [
    "dist",
    "dist-cli"
  ],
  "scripts": {
    "dev": "vite --config vite.config.demo.ts",
    "build:lib": "vite build --config vite.config.lib.ts",
    "build:cli": "vite build --config vite.config.cli.ts",
    "build:demo": "vite build --config vite.config.demo.ts",
    "build": "pnpm build:lib && pnpm build:cli && pnpm build:demo",
    "preview": "vite preview --config vite.config.demo.ts",
    "prepublishOnly": "pnpm build:lib && pnpm build:cli"
  },
  "peerDependencies": {
    "@radix-ui/react-tooltip": "^1.2.0",
    "@radix-ui/themes": "^3.0.0",
    "rdflib": "^2.3.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "react-intersection-observer": "^10.0.3",
    "smooth-scroll-into-view-if-needed": "^2.0.2"
  },
  "devDependencies": {
    "@rdfjs/types": "^2.0.1",
    "@types/node": "^20.19.33",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "gh-pages": "^6.3.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-dts": "^4.5.4"
  }
}
